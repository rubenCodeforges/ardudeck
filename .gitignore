*.tmp

# Claude Code
.claude/

# Legacy Mission Planner (reference repo, not part of this project)
MissionPlanner/

# Reference implementations (not part of this project)
inav-configurator/
betaflight-configurator/
MissionPlanner-ref/
qgroundcontrol/

# Firmware files (downloaded on-demand from ArduPilot servers)
# Note: Don't ignore apps/desktop/src/main/firmware/ (source code)
/firmware/
/firmwares/
**/ardudeck-firmware/
*.apj
*.px4

# Generated MAVLink types (can be regenerated)
# packages/mavlink-ts/src/generated/

# Electron store data
%APPDATA%/ardudeck/

# MAVLink logs and parameter dumps
*.tlog
*.tlog.raw
*.parm

# Debug
.debug/
inav-configurator

# Dev-only test driver discovery file
.ardudeck-mcp.json
# MediaMTX auto-generated self-signed TLS cert/key (regenerated on demand; never commit a private key)
auto.crt
auto.key
**/auto.crt
**/auto.key
reference/

# Locally-built media/receiver binaries (bundled by CI, never committed)
apps/desktop/resources/bin/*/ardudeck-wfb-rx*

# Bundled multi-vehicle engine binary (fetched at package time, see engine.json)
apps/desktop/engine/
